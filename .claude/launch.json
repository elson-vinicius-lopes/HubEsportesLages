{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hub-web",
      "runtimeExecutable": "dotnet",
      "runtimeArgs": [
        "run",
        "--project",
        "src/HubEsportesLages.Web/HubEsportesLages.Web.csproj",
        "--no-launch-profile",
        "--urls",
        "http://0.0.0.0:5210"
      ],
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      },
      "port": 5210,
      "autoPort": false
    }
  ]
}
