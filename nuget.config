<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <!-- Ignora feeds privados configurados na máquina e usa apenas o NuGet oficial -->
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
