@model ContaViewModel
@{
    ViewData["Title"] = "Meu Painel";
}

<section class="detalhe-hero" style="background: linear-gradient(135deg, var(--azul-900), var(--verde));">
    <div class="container">
        <h1>Meu Painel</h1>
        <p class="lead" style="color:#e6f4ec; margin:0;">
            Acompanhe o engajamento do Bora pro Jogo, visualize o mapa sazonal de eventos de Lages e configure suas notificações.
        </p>
    </div>
</section>

<section class="section--tight">
    <div class="container">

        <!-- ── DASHBOARD DE MÉTRICAS ── -->
        <div class="dash-grid">
            <div class="dash-card">
                <span class="dash-card__label">Total de Eventos</span>
                <span class="dash-card__value">@Model.Metricas.TotalEventos</span>
                <span class="dash-card__desc">Na agenda do Bora pro Jogo</span>
            </div>
            <div class="dash-card">
                <span class="dash-card__label">Inscrições Ativas</span>
                <span class="dash-card__value">@Model.Metricas.TotalInscricoes</span>
                <span class="dash-card__desc">Torcedores recebendo alertas</span>
            </div>
            <div class="dash-card">
                <span class="dash-card__label">Torcedores Engajados</span>
                <span class="dash-card__value">@Model.Metricas.TotalParticipantesAtivos</span>
                <span class="dash-card__desc">Participações em enquetes/mural</span>
            </div>
            <div class="dash-card">
                <span class="dash-card__label">Mensagens no Mural</span>
                <span class="dash-card__value">@Model.Metricas.TotalMensagensMural</span>
                <span class="dash-card__desc">Interações acumuladas</span>
            </div>
        </div>

        <!-- ── MAPA SAZONAL ── -->
        @{
            var startSunday = DateTime.Today.AddDays(-364);
            startSunday = startSunday.AddDays(-(int)startSunday.DayOfWeek);
            var eventosDict = Model.Metricas.EventosPorDia.ToDictionary(m => m.Data.Date, m => m.QuantidadeEventos);
        }
        <div class="heatmap-container">
            <div class="heatmap-header">
                <h3 style="margin:0;">Mapa Sazonal de Eventos (Agenda Anual)</h3>
                <div class="heatmap-legend">
                    <span>Menos</span>
                    <div class="heatmap-legend-box heatmap-day--level-0" title="0 eventos"></div>
                    <div class="heatmap-legend-box heatmap-day--level-1" title="1 evento"></div>
                    <div class="heatmap-legend-box heatmap-day--level-2" title="2 eventos"></div>
                    <div class="heatmap-legend-box heatmap-day--level-3" title="3 eventos"></div>
                    <div class="heatmap-legend-box heatmap-day--level-4" title="4+ eventos"></div>
                    <span>Mais</span>
                </div>
            </div>
            <div class="heatmap-grid-wrapper">
                <div class="heatmap-grid">
                    @for (int col = 0; col < 53; col++)
                    {
                        for (int row = 0; row < 7; row++)
                        {
                            var currentDate = startSunday.AddDays(col * 7 + row);
                            var count = eventosDict.TryGetValue(currentDate, out var c) ? c : 0;
                            var level = count switch
                            {
                                0 => 0,
                                1 => 1,
                                2 => 2,
                                3 => 3,
                                _ => 4
                            };
                            var isFuture = currentDate > DateTime.Today;
                            var levelClass = isFuture ? "heatmap-day--level-0" : $"heatmap-day--level-{level}";
                            var tooltipText = $"{currentDate:dd/MM/yyyy}: {(isFuture ? "Sem eventos (futuro)" : $"{count} evento(s)")}";
                            
                            <div class="heatmap-day @levelClass" title="@tooltipText"></div>
                        }
                    }
                </div>
            </div>
            <div class="heatmap-labels">
                <span>@startSunday.ToString("MMM/yyyy")</span>
                <span>@startSunday.AddMonths(3).ToString("MMM/yyyy")</span>
                <span>@startSunday.AddMonths(6).ToString("MMM/yyyy")</span>
                <span>@startSunday.AddMonths(9).ToString("MMM/yyyy")</span>
                <span>Hoje (@DateTime.Today.ToString("dd/MM"))</span>
            </div>
        </div>

        <!-- ── TABELA DE ENGAJAMENTO POR EVENTO ── -->
        <div class="table-panel">
            <h3 style="margin:0 0 6px;">Pessoas no Evento (Participação Ativa)</h3>
            <p class="muted" style="margin:0 0 16px;">Quantidade de torcedores únicos que interagiram votando ou escrevendo no mural em cada um dos confrontos recentes.</p>
            <div style="overflow-x:auto;">
                <table class="dash-table">
                    <thead>
                        <tr>
                            <th>Evento</th>
                            <th>Data</th>
                            <th>Participantes Únicos</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var ev in Model.Metricas.EngajamentoPorEvento)
                        {
                            <tr>
                                <td style="font-weight:700;">
                                    <span style="margin-right:6px;">@ev.ModalidadeIcone</span> @ev.Titulo
                                </td>
                                <td style="color:var(--texto-suave);">@ev.Inicio.ToString("dd/MM/yyyy HH:mm")</td>
                                <td>
                                    <span class="badge-participantes">@ev.ParticipantesUnicos torcedores</span>
                                </td>
                                <td>
                                    @if (ev.Inicio.Date == DateTime.Today)
                                    {
                                        <span class="badge badge--aovivo" style="font-size: 0.72rem; padding: 2px 8px;">Hoje</span>
                                    }
                                    else if (ev.Inicio > DateTime.Now)
                                    {
                                        <span class="badge badge--agendado" style="font-size: 0.72rem; padding: 2px 8px;">Agendado</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge--encerrado" style="font-size: 0.72rem; padding: 2px 8px;">Encerrado</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- ── FEED DE PRÓXIMOS EVENTOS + FORMULÁRIO DE INSCRIÇÃO ── -->
        <div class="admin-layout-grid">
            <div class="painel">
                <h3>Gerenciar alertas de notificações</h3>
                <p class="muted" style="margin-top:-4px;">Escolha quais modalidades e equipes você deseja acompanhar por e-mail ou push.</p>

                @if (TempData["InscricaoOk"] is string ok)
                {
                    <div class="alerta alerta--ok">✅ @ok</div>
                }

                <div asp-validation-summary="ModelOnly" class="text-erro"></div>

                <form asp-action="Inscrever" asp-controller="Notificacoes" method="post" class="form-grid">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="returnUrl" value="/conta" />

                    <div class="campo col-full">
                        <label asp-for="Inscricao.Nome">Nome</label>
                        <input asp-for="Inscricao.Nome" placeholder="Seu nome" required />
                        <span asp-validation-for="Inscricao.Nome" class="text-erro"></span>
                    </div>

                    <div class="campo col-full">
                        <label asp-for="Inscricao.Email">E-mail</label>
                        <input asp-for="Inscricao.Email" placeholder="voce@email.com" required />
                        <span asp-validation-for="Inscricao.Email" class="text-erro"></span>
                    </div>

                    <div class="campo col-full">
                        <label asp-for="Inscricao.Telefone">Telefone (opcional)</label>
                        <input asp-for="Inscricao.Telefone" placeholder="(49) 9 9999-9999" />
                        <span asp-validation-for="Inscricao.Telefone" class="text-erro"></span>
                    </div>

                    <div class="campo">
                        <label asp-for="Inscricao.ModalidadeId">Modalidade</label>
                        <select asp-for="Inscricao.ModalidadeId">
                            <option value="">Todas</option>
                            @foreach (var m in Model.Modalidades)
                            {
                                <option value="@m.Id">@m.Icone @m.Nome</option>
                            }
                        </select>
                    </div>

                    <div class="campo">
                        <label asp-for="Inscricao.EquipeId">Equipe</label>
                        <select asp-for="Inscricao.EquipeId">
                            <option value="">Todas</option>
                            @foreach (var e in Model.Equipes)
                            {
                                <option value="@e.Id">@e.Escudo @e.Nome</option>
                            }
                        </select>
                    </div>

                    <label class="check col-full"><input asp-for="Inscricao.ReceberEmail" type="checkbox" checked /> Receber por e-mail</label>
                    <label class="check col-full"><input asp-for="Inscricao.ReceberPush" type="checkbox" /> Receber notificações push</label>

                    <div class="col-full">
                        <button class="btn btn--primary btn--block" type="submit">Salvar preferências de alerta</button>
                    </div>
                </form>
            </div>

            <aside>
                <div class="painel">
                    <h3>Próximos eventos da agenda</h3>
                    <div class="feed">
                        @foreach (var e in Model.Proximos)
                        {
                            <div class="feed-item feed-item--novoevento">
                                <div class="feed-item__icone" style="background:@e.ModalidadeCor">@e.ModalidadeIcone</div>
                                <div class="feed-item__corpo">
                                    <div class="feed-item__topo">
                                        <p class="feed-item__titulo">@e.Titulo</p>
                                        <span class="feed-item__hora">@DiaMes(e.Inicio)</span>
                                    </div>
                                    <p class="feed-item__msg">@e.LocalNome · @Hora(e.Inicio)</p>
                                    <a class="btn btn--outline btn--sm" style="margin-top:8px; display:inline-block;"
                                       asp-controller="Agenda" asp-action="Index">Ver na Agenda →</a>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </aside>
        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
