@{
    ViewData["Title"] = "Entrar";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

<section class="section hero" style="min-height: 80vh; display: grid; place-items: center;">
    <div class="container" style="max-width: 460px; width: 100%;">
        
        <div class="painel" style="background: rgba(11, 37, 69, 0.9); backdrop-filter: blur(12px); border: 1.5px solid rgba(255, 255, 255, 0.15); box-shadow: var(--sombra-lg); color: #fff;">
            
            <div class="center" style="margin-bottom: 28px;">
                <div class="brand__logo" style="margin: 0 auto 16px; width: 56px; height: 56px; font-size: 1.8rem; background: linear-gradient(135deg, var(--verde), var(--azul-600));">
                    <img src="~/assets/logo.png" alt="Bora pro Jogo" style="width: 100%; height: 100%; object-fit: cover; border-radius: inherit;" />
                </div>
                <h2 style="font-size: 1.8rem; margin: 0; color: #fff; font-weight: 700;">Entrar</h2>
                <p class="muted" style="margin: 6px 0 0; color: #cbd5e1; font-size: 0.92rem;">Acesse sua conta para acompanhar os eventos esportivos de Lages.</p>
            </div>

            @if (TempData["RegistroOk"] != null)
            {
                <div class="alerta" style="background: rgba(34, 197, 94, 0.15); border: 1.5px solid var(--verde); color: #bbf7d0; margin-bottom: 20px;">
                    <span>✅</span>
                    <div style="font-size: 0.9rem;">@TempData["RegistroOk"]</div>
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alerta" style="background: rgba(220, 38, 38, 0.15); border: 1.5px solid var(--vermelho); color: #fecaca; margin-bottom: 20px;">
                    <span>⚠️</span>
                    <div style="font-size: 0.9rem;">
                        @foreach (var modelState in ViewData.ModelState.Values)
                        {
                            foreach (var error in modelState.Errors)
                            {
                                <span>@error.ErrorMessage</span>
                            }
                        }
                    </div>
                </div>
            }

            <form asp-action="Login" asp-controller="Conta" method="post" style="display: flex; flex-direction: column; gap: 18px;">
                @Html.AntiForgeryToken()
                <input type="hidden" name="returnUrl" value="@returnUrl" />

                <div class="campo">
                    <label for="username" style="color: #cbd5e1; font-weight: 600; font-size: 0.78rem;">Usuário ou E-mail</label>
                    <input type="text" id="username" name="username" required placeholder="Ex.: joao@email.com" 
                           style="background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.15); color: #fff; font-size: 0.95rem; padding: 12px 14px;" />
                </div>

                <div class="campo">
                    <label for="password" style="color: #cbd5e1; font-weight: 600; font-size: 0.78rem;">Senha</label>
                    <input type="password" id="password" name="password" required placeholder="Digite sua senha" 
                           style="background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.15); color: #fff; font-size: 0.95rem; padding: 12px 14px;" />
                </div>

                <button class="btn btn--primary btn--block" type="submit" style="margin-top: 10px; padding: 13px; font-size: 1rem; border-radius: 12px;">
                    Entrar
                </button>
            </form>

            <div class="center" style="margin-top: 20px;">
                <a asp-controller="Conta" asp-action="Registrar" 
                   style="display: block; width: 100%; padding: 13px; font-size: 1rem; border-radius: 12px; 
                          border: 1.5px solid var(--verde); color: var(--verde); background: transparent; 
                          text-align: center; font-weight: 600; text-decoration: none; 
                          transition: background 0.25s, color 0.25s;">
                    Criar minha conta
                </a>
            </div>

            <div class="center" style="margin-top: 20px; display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
                <a asp-controller="Admin" asp-action="Login" style="color: #94a3b8; font-weight: 500; font-size: 0.85rem; transition: color 0.2s;">
                    Sou organizador →
                </a>
            </div>

            <div class="center" style="margin-top: 12px;">
                <a href="/" style="color: var(--verde); font-weight: 600; font-size: 0.88rem; transition: color 0.2s;">
                    ← Voltar para o início
                </a>
            </div>

        </div>

    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
