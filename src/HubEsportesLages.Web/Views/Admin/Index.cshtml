@model AdminViewModel
@{
    ViewData["Title"] = "Área do organizador";
}

<section class="detalhe-hero" style="background: linear-gradient(135deg, var(--azul-900), var(--azul-600));">
    <div class="container">
        <h1>🛠️ Área do organizador</h1>
        <p class="lead" style="color:#d6e0ee; margin:0;">
            Publique eventos na agenda do hub. Ao salvar, uma notificação automática é enviada aos torcedores.
        </p>
    </div>
</section>

<section class="section--tight">
    <div class="container" style="display:grid; gap:26px; grid-template-columns: 1.5fr 1fr; align-items:start;">

        <div class="painel">
            <h3>Publicar novo evento</h3>

            @if (TempData["EventoOk"] is string ok)
            {
                <div class="alerta alerta--ok">✅ @ok</div>
            }

            <div asp-validation-summary="ModelOnly" class="text-erro"></div>

            <form asp-action="Criar" method="post" class="form-grid">
                @Html.AntiForgeryToken()

                <div class="campo col-full">
                    <label asp-for="Evento.Titulo">Título do evento</label>
                    <input asp-for="Evento.Titulo" placeholder="Ex.: Lages FC x Guarani de Lages" />
                    <span asp-validation-for="Evento.Titulo" class="text-erro"></span>
                </div>

                <div class="campo">
                    <label asp-for="Evento.ModalidadeId">Modalidade</label>
                    <select asp-for="Evento.ModalidadeId">
                        <option value="">Selecione...</option>
                        @foreach (var m in Model.Modalidades)
                        {
                            <option value="@m.Id">@m.Icone @m.Nome</option>
                        }
                    </select>
                    <span asp-validation-for="Evento.ModalidadeId" class="text-erro"></span>
                </div>
                <div class="campo">
                    <label asp-for="Evento.LocalId">Local</label>
                    <select asp-for="Evento.LocalId">
                        <option value="">Selecione...</option>
                        @foreach (var l in Model.Locais)
                        {
                            <option value="@l.Id">@l.Nome</option>
                        }
                    </select>
                    <span asp-validation-for="Evento.LocalId" class="text-erro"></span>
                </div>

                <div class="campo">
                    <label asp-for="Evento.EquipeCasaId">Equipe mandante (opcional)</label>
                    <select asp-for="Evento.EquipeCasaId">
                        <option value="">—</option>
                        @foreach (var e in Model.Equipes)
                        {
                            <option value="@e.Id">@e.Escudo @e.Nome</option>
                        }
                    </select>
                </div>
                <div class="campo">
                    <label asp-for="Evento.EquipeVisitanteId">Equipe visitante (opcional)</label>
                    <select asp-for="Evento.EquipeVisitanteId">
                        <option value="">—</option>
                        @foreach (var e in Model.Equipes)
                        {
                            <option value="@e.Id">@e.Escudo @e.Nome</option>
                        }
                    </select>
                    <span asp-validation-for="Evento.EquipeVisitanteId" class="text-erro"></span>
                </div>

                <div class="campo col-full">
                    <label asp-for="Evento.Campeonato">Campeonato</label>
                    <input asp-for="Evento.Campeonato" placeholder="Ex.: Campeonato Citadino de Futebol 2026" />
                </div>

                <div class="campo">
                    <label asp-for="Evento.Inicio">Início</label>
                    <input asp-for="Evento.Inicio" type="datetime-local" />
                    <span asp-validation-for="Evento.Inicio" class="text-erro"></span>
                </div>
                <div class="campo">
                    <label asp-for="Evento.Fim">Término (opcional)</label>
                    <input asp-for="Evento.Fim" type="datetime-local" />
                </div>

                <div class="campo col-full">
                    <label asp-for="Evento.Descricao">Descrição</label>
                    <input asp-for="Evento.Descricao" placeholder="Detalhes do evento, ingressos, observações..." />
                </div>

                <div class="campo">
                    <label asp-for="Evento.PrecoIngresso">Preço do ingresso (R$)</label>
                    <input asp-for="Evento.PrecoIngresso" type="number" step="0.01" min="0" placeholder="0,00" />
                </div>
                <div class="campo" style="justify-content:flex-end;">
                    <label class="check"><input asp-for="Evento.Gratuito" type="checkbox" /> Evento gratuito</label>
                    <label class="check"><input asp-for="Evento.Destaque" type="checkbox" /> Exibir em destaque</label>
                </div>

                <div class="col-full">
                    <button class="btn btn--primary btn--block" type="submit">📢 Publicar na agenda</button>
                </div>
            </form>
        </div>

        <aside>
            <div class="painel">
                <h3>Próximos publicados</h3>
                <div class="feed">
                    @foreach (var e in Model.Proximos)
                    {
                        <div class="feed-item feed-item--novoevento">
                            <div class="feed-item__icone" style="background:@e.ModalidadeCor">@e.ModalidadeIcone</div>
                            <div class="feed-item__corpo">
                                <div class="feed-item__topo">
                                    <p class="feed-item__titulo">@e.Titulo</p>
                                    <span class="feed-item__hora">@DiaMes(e.Inicio)</span>
                                </div>
                                <p class="feed-item__msg">@e.LocalNome · @Hora(e.Inicio)</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </aside>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
